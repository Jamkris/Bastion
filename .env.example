# Login password (single-password mode). Leave empty to run open (dev/demo).
# Once you add users on the Settings page, Bastion switches to multi-user login
# and this password is ignored.
BASTION_AUTH_PASSWORD=
# Secret used to sign multi-user session cookies. Optional — if unset, a random
# key is generated and stored at <data_dir>/.secret. Set it to share sessions
# across replicas or to control rotation.
# BASTION_SECRET_KEY=
# Only needed for bare-metal (systemd) runs as an unprivileged user. Leave as-is for Docker.
BASTION_SUDO=false
# Jails to query (empty -> auto-discover via `fail2ban-client status`)
# BASTION_JAILS=sshd
# Path to a DB-IP/GeoLite2 country .mmdb (Docker sets this automatically).
# Override only to use your own database.
# BASTION_GEOIP_DB=/geoip/dbip-country-lite.mmdb
# Auth log path (default /var/log/auth.log, falls back to journald)
# BASTION_AUTH_LOG=/var/log/auth.log
# Demo mode: serve sample data instead of running commands
# BASTION_DEMO=false
# Directory for runtime state (Settings-page preferences). Mount it as a volume
# in Docker so notification/allowlist/security settings survive restarts.
# BASTION_DATA_DIR=data
# fail2ban jail.local path, edited when the "Persist to jail.local" allowlist
# option is on. Mount it read-write in Docker for persistence to work.
# BASTION_JAIL_LOCAL=/etc/fail2ban/jail.local
#
# Notifications (ntfy), the allowlist target set, and login rate limits are all
# configured at runtime from the in-app Settings page — not via env vars.
