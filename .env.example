# 베어메탈(systemd)에서 비권한 유저로 돌릴 때만 필요. Docker면 기본값 그대로.
BASTION_SUDO=false
# 조회할 jail (비우면 fail2ban-client status로 자동 발견)
# BASTION_JAILS=sshd
# GeoLite2 국가 DB 경로 (있으면 국가 컬럼 채워짐)
# BASTION_GEOIP_DB=/geoip/GeoLite2-Country.mmdb
# auth.log 경로 (기본 /var/log/auth.log, 없으면 journald 폴백)
# BASTION_AUTH_LOG=/var/log/auth.log
